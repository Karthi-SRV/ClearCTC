REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb://localhost:27017/comp-copilot
DATA_SOURCE=cached
STALE_DATA_THRESHOLD_DAYS=90
LOKI_URL=http://loki:3100
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────────────────────────────
# Origin of the frontend (required in production)
ALLOWED_ORIGIN=http://localhost:5173

# ── Auth ───────────────────────────────────────────────────────────────────────
# Required — use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ── Admin ──────────────────────────────────────────────────────────────────────
# Required to call POST /api/v1/city-expenses/refresh
# Pass as X-Admin-Token header
ADMIN_TOKEN=change-me-to-a-random-string-in-production

# ── Grafana ────────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production

# ── AI provider selection ──────────────────────────────────────────────────────
# Values: claude | gemini | ollama | google
AI_PROVIDER=gemini

# ── Gemini (Google AI Studio — FREE tier, no billing required) ────────────────
# Get a free key at: https://aistudio.google.com/apikey
# Free limits: 15 RPM, 1 000 000 tokens/day, no credit card needed
GEMINI_API_KEY=AIza...
# Models: gemini-2.0-flash | gemini-1.5-flash | gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash

# ── Claude (Anthropic direct) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Models: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Models: gpt-4o | gpt-4o-mini | gpt-4-turbo | o1-preview
OPENAI_MODEL=gpt-4o

# ── AWS Bedrock (uses standard AWS credential chain) ───────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
# Models: anthropic.claude-3-5-sonnet-20241022-v2:0 | amazon.titan-text-express-v1 | meta.llama3-70b-instruct-v1:0
BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── Google Vertex AI (uses Application Default Credentials) ────────────────────
# Run: gcloud auth application-default login
VERTEX_PROJECT=my-gcp-project
VERTEX_LOCATION=us-central1
# Models: gemini-1.5-pro | gemini-1.5-flash | gemini-2.0-flash-001
VERTEX_MODEL=gemini-1.5-pro

# ── Ollama (local, via Docker) ─────────────────────────────────────────────────
# Inside Docker network: http://ollama:11434
# Local dev (if ollama on host): http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
# Pull model automatically: ./scripts/infra.sh [model-name]
# Or manually: docker compose exec ollama ollama pull llama3.2
# Models: llama3.2 | mistral | phi3 | deepseek-r1 | qwen2.5-coder | neural-chat
OLLAMA_MODEL=llama3.2
